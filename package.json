{
  "name": "lbe-extension",
  "description": "LBE Wallet Extension",
  "private": true,
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "verify:stage2:compile": "tsc --noEmit",
    "verify:stage2:smoke": "node scripts/verify-stage2-smoke.mjs",
    "verify:stage2:integration": "node scripts/verify-stage2-integration.mjs",
    "verify:stage2:stability": "node scripts/verify-stage2-stability-contract.mjs",
    "verify:stage2": "yarn verify:stage2:compile && yarn verify:stage2:smoke && yarn verify:stage2:integration && yarn verify:stage2:stability",
    "verify:css:colors": "node scripts/verify-css-colors.mjs",
    "verify:i18n": "node scripts/verify-i18n.mjs",
    "verify:browser:e2e": "node tests/e2e/verify-browser-e2e-regression-baseline.mjs",
    "verify:browser:e2e:gating": "node tests/e2e/verify-browser-e2e-regression-gating.mjs",
    "verify:browser:e2e:gate": "yarn build && yarn verify:stage2 && yarn verify:browser:e2e",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@cosmjs/amino": "^0.36.0",
    "@cosmjs/encoding": "^0.36.0",
    "@cosmjs/proto-signing": "^0.36.0",
    "@cosmjs/stargate": "^0.36.0",
    "@cosmjs/tendermint-rpc": "^0.36.0",
    "@noble/hashes": "^1.5.2",
    "@reduxjs/toolkit": "^2.2.6",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^2.0.1",
    "ahooks": "^3.8.0",
    "antd": "^5.19.0",
    "bech32": "^2.0.0",
    "blo": "^1.2.0",
    "browser-passworder": "^2.0.3",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^3.3.3",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "debounce": "1.2.1",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "events": "^3.3.0",
    "i18next": "^23.11.5",
    "jsencrypt": "^3.3.2",
    "koa-compose": "^4.1.0",
    "long": "^5.2.0",
    "lru-cache": "6.0.0",
    "nanoid": "^5.0.7",
    "qrcode.react": "^3.1.0",
    "randomstring": "^1.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.2",
    "react-idle-timer": "^5.7.2",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.23.1",
    "react-use": "^17.5.0",
    "redux-localstorage-simple": "^2.5.1",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^2.3.0",
    "uuidv7": "^1.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.0.3",
    "@eslint/js": "^9.4.0",
    "@types/chrome": "^0.0.268",
    "@types/crypto-js": "^4.2.2",
    "@types/debounce": "^1.2.4",
    "@types/koa-compose": "^3.2.8",
    "@types/lru-cache": "^5.1.0",
    "@types/randomstring": "^1.3.0",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.4.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.2",
    "globals": "^15.3.0",
    "less": "^4.5.1",
    "prettier": "^3.3.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.12.0",
    "wxt": "^0.17.0"
  }
}
